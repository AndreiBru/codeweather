{
  "name": "codeweather",
  "version": "0.3.0",
  "description": "Zero-config code quality audits for JS/TS projects with trend history and a self-contained dashboard.",
  "type": "module",
  "bin": {
    "codeweather": "./bin/codeweather.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "self": "node bin/codeweather.js"
  },
  "keywords": [
    "code-quality",
    "static-analysis",
    "unused-code",
    "duplicates",
    "circular-dependencies",
    "dependency-graph",
    "dashboard",
    "trending",
    "history",
    "scc",
    "knip",
    "jscpd",
    "dependency-cruiser",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "citty": "0.1.6",
    "dependency-cruiser": "17.3.8",
    "execa": "9.6.1",
    "jscpd": "4.0.8",
    "knip": "5.86.0",
    "lilconfig": "3.1.3",
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
